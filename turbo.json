{
	"$schema": "https://turborepo.org/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["*.ts", "package.json", "tsconfig*json"],
			"outputs": ["dist", "*.tsbuildinfo"]
		},
		"clean": {
			"cache": false
		},
		"coverage": {
			"dependsOn": ["^build"],
			"outputs": ["coverage/**"]
		},
		"lint": {
			"dependsOn": ["^build"]
		},
		"nuke": {
			"cache": false
		},
		"sb": {
			"dependsOn": ["^build"]
		},
		"sb:build": {
			"dependsOn": ["^build"]
		},
		"size": {
			"dependsOn": ["build"]
		},
		"test": {
			"dependsOn": ["^build"]
		}
	}
}
