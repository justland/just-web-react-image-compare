{
	"private": true,
	"license": "MIT",
	"scripts": {
		"build": "turbo run build",
		"build:docs": "rup-s sb:build",
		"check": "run-p check:* lint:*",
		"check:biome": "biome check",
		"clean": "turbo run clean",
		"coverage": "turbo run coverage",
		"cs": "changeset",
		"fix": "biome check --write",
		"knip": "knip",
		"lint:eslint": "cross-env TIMING=1 eslint --max-warnings 0",
		"nuke": "turbo run nuke && pnpm nuke:root",
		"nuke:root": "rimraf node_modules",
		"prepare": "husky",
		"release": "changeset publish",
		"ric": "pnpm --filter=./packages/react-image-compare",
		"sb": "turbo run sb",
		"sb:build": "turbo run sb:build",
		"size": "turbo run size",
		"test": "turbo run test",
		"verify": "run-p check knip verify:p",
		"verify:p": "turbo run build coverage size",
		"version": "changeset version"
	},
	"dependencies": {
		"@types/react": "^19.2.8"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"@changesets/cli": "^2.29.2",
		"@commitlint/cli": "^20.0.0",
		"@commitlint/config-conventional": "^20.0.0",
		"@eslint/compat": "^2.0.0",
		"@repobuddy/biome": "2.3.0",
		"cross-env": "^10.0.0",
		"eslint": "^9.39.2",
		"eslint-plugin-formatjs": "^6.0.0",
		"globals": "^17.0.0",
		"husky": "^9.1.7",
		"knip": "^5.81.0",
		"npm-run-all2": "^8.0.0",
		"playwright": "^1.57.0",
		"rimraf": "^6.1.0",
		"turbo": "^2.5.1",
		"typescript": "^5.9.3"
	},
	"packageManager": "pnpm@10.28.1"
}
